# ── Network ──────────────────────────────────────────────────────────────────
# "production" uses Polygon; anything else uses Sepolia
VITE_ENV=development

# ── RPC URLs ─────────────────────────────────────────────────────────────────
VITE_RPC_URL=                        # Sepolia RPC URL
VITE_POLYGON_RPC_URL=                # Polygon RPC URL
VITE_BASE_RPC_URL=                   # Base RPC URL

# ── OTC Contract Addresses ───────────────────────────────────────────────────
VITE_OTC_CONTRACT_SEPOLIA=
VITE_OTC_CONTRACT_POLYGON=
VITE_OTC_CONTRACT_BASE=

# ── Premarket Contract Addresses ─────────────────────────────────────────────
VITE_PREMARKET_CONTRACT_SEPOLIA=
VITE_PREMARKET_CONTRACT_POLYGON=
VITE_PREMARKET_CONTRACT_BASE=
